{
  "name": "portfolio-202606",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "description": "강주형 포트폴리오 — Next.js 16 + HeroUI v3 기반 정적 사이트",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "export:pdf": "tsx scripts/generate-pdf.ts",
    "export:pdf:resume": "tsx scripts/generate-pdf.ts --only=resume",
    "export:pdf:portfolio": "tsx scripts/generate-pdf.ts --only=portfolio",
    "pdf": "concurrently --kill-others --success first --names \"dev,pdf\" \"next dev\" \"tsx scripts/generate-pdf.ts\"",
    "gh-deploy": "pnpm pdf && next build && node scripts/gh-deploy.mjs"
  },
  "dependencies": {
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
